# Faro — configuración por ENV (ADR-009). Copia este archivo a `.env` y completa los valores.
# `.env` está en .gitignore: el secreto nunca se versiona.
#
#   cp .env.example .env   &&   editar .env con tu API key
#
# API key de la CMF (fuente v1, ADR-002). Solicitada en https://api.sbif.cl/api/contactanos.jsp
CMF_API_KEY=

# Puerto del servidor HTTP
PORT=8080

# Conexión a PostgreSQL (VibeNest inyecta un DATABASE_URL en prod)
DATABASE_URL=postgres://faro:faro@localhost:5432/faro?sslmode=disable

# Fuente activa e intervalo de refresco (opcionales; defaults razonables en código)
FARO_SOURCE=cmf
REFRESH_INTERVAL=24h

# Solo para correr los tests de integración del store. Debe apuntar a una BD
# cuyo nombre contenga "test" (los tests la BORRAN y re-migran en cada corrida):
#   docker exec faro-pg createdb -U faro faro_test   # una vez
# FARO_TEST_DATABASE_URL=postgres://faro:faro@localhost:5432/faro_test?sslmode=disable
